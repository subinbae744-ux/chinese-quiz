<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>중국어 성조 & 한자 암기 퀴즈</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .perspective-1000 { perspective: 1000px; }
        .transform-style-3d { transform-style: preserve-3d; }
        .backface-hidden { backface-visibility: hidden; }
        .rotate-y-180 { transform: rotateY(180deg); }
    </style>
</head>
<body class="bg-stone-50 text-stone-800 font-sans min-h-screen flex flex-col justify-between">

    <div id="home-view" class="container mx-auto px-4 max-w-md flex-grow flex flex-col justify-center items-center py-12">
        <div class="text-center mb-10">
            <span class="bg-emerald-100 text-emerald-800 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider mb-3 inline-block">Vibe Coding Project</span>
            <h1 class="text-3xl font-extrabold text-stone-900 tracking-tight">중국어 성조 & 한자<br><span class="text-emerald-600">암기 마스터</span></h1>
            <p class="text-stone-500 mt-2 text-sm">전공 수업부터 HSK 자격증까지 한 번에!</p>
        </div>

        <div class="w-full space-y-4">
            <button onclick="switchView('flashcard-view'); initFlashcard();" class="w-full py-4 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-2xl shadow-md flex items-center justify-center gap-3 text-lg cursor-pointer">
                <i class="fa-solid fa-layer-group"></i> 1단계: 단어장 학습 시작
            </button>
            <button onclick="switchView('quiz-view'); startQuiz();" class="w-full py-4 bg-white hover:bg-stone-100 text-stone-800 font-bold rounded-2xl shadow-sm border border-stone-200 flex items-center justify-center gap-3 text-lg cursor-pointer">
                <i class="fa-solid fa-graduation-cap text-emerald-500"></i> 2단계: 성조 퀴즈 도전
            </button>
        </div>
    </div>

    <div id="flashcard-view" class="container mx-auto px-4 max-w-md flex-grow hidden flex-col justify-between py-6">
        <div>
            <div class="flex justify-between items-center mb-4">
                <button onclick="switchView('home-view')" class="text-stone-500 hover:text-stone-800 text-sm flex items-center gap-1 cursor-pointer">
                    <i class="fa-solid fa-chevron-left"></i> 홈으로
                </button>
                <div class="flex items-center gap-2 bg-white px-3 py-1.5 rounded-lg border border-stone-200 text-xs shadow-sm">
                    <input type="checkbox" id="filter-review" onchange="toggleFilter(this)" class="accent-emerald-600 h-4 w-4 rounded cursor-pointer">
                    <label for="filter-review" class="font-medium text-stone-600 cursor-pointer">'몰라요' 단어만 보기</label>
                </div>
            </div>
            <div class="w-full bg-stone-200 h-2 rounded-full overflow-hidden mb-6">
                <div id="flashcard-progress" class="bg-emerald-500 h-full" style="width: 0%"></div>
            </div>
        </div>

        <div class="flex-grow flex items-center justify-center my-4">
            <div id="flashcard-container" class="w-full h-72 perspective-1000 cursor-pointer" onclick="flipCard()">
                <div id="flashcard" class="w-full h-full transform-style-3d transition-transform duration-500 relative bg-white rounded-3xl shadow-sm border border-stone-200 flex items-center justify-center">
                    <div class="absolute inset-0 backface-hidden flex flex-col items-center justify-center p-6 text-center">
                        <span class="text-xs text-stone-400 mb-4 tracking-widest"><i class="fa-solid fa-eye"></i> 터치해서 뒤집기</span>
                        <h2 id="card-hanzi" class="text-6xl font-bold text-stone-900">学习</h2>
                    </div>
                    <div class="absolute inset-0 backface-hidden rotate-y-180 bg-emerald-50 rounded-3xl border-2 border-emerald-300 flex flex-col items-center justify-center p-6 text-center">
                        <span class="text-xs text-emerald-600 font-bold mb-2">정답 확인</span>
                        <h3 id="card-pinyin" class="text-3xl font-bold text-emerald-700 mb-2">xuéxí</h3>
                        <p id="card-meaning" class="text-xl text-stone-600">공부하다</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-4">
            <button onclick="classifyWord(false)" class="py-3.5 bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 font-bold rounded-xl flex items-center justify-center gap-2 cursor-pointer">
                <i class="fa-solid fa-circle-xmark"></i> 몰라요
            </button>
            <button onclick="classifyWord(true)" class="py-3.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-600 border border-emerald-200 font-bold rounded-xl flex items-center justify-center gap-2 cursor-pointer">
                <i class="fa-solid fa-circle-check"></i> 알아요
            </button>
        </div>
    </div>

    <div id="quiz-view" class="container mx-auto px-4 max-w-md flex-grow hidden flex-col justify-between py-6">
        <div>
            <div class="flex justify-between items-center mb-3">
                <span id="quiz-progress-txt" class="text-sm font-semibold text-stone-500">문제 1 / 10</span>
                <div class="bg-emerald-50 text-emerald-700 font-bold px-3 py-1 rounded-lg text-sm border border-emerald-200">
                    Score: <span id="quiz-score">0</span>
                </div>
            </div>
            <div class="w-full bg-stone-200 h-2 rounded-full overflow-hidden mb-6">
                <div id="timer-bar" class="bg-amber-500 h-full" style="width: 100%"></div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-stone-200 p-8 text-center my-4 flex-grow flex flex-col items-center justify-center relative">
            <div id="quiz-feedback" class="absolute inset-0 bg-white/95 rounded-3xl flex flex-col items-center justify-center hidden z-10">
                <span id="feedback-icon" class="text-7xl mb-2"></span>
                <p id="feedback-text" class="text-lg font-bold text-stone-700"></p>
            </div>
            <span class="text-xs text-stone-400 uppercase tracking-widest font-semibold mb-4">알맞은 성조와 병음을 고르세요</span>
            <h2 id="quiz-hanzi" class="text-7xl font-extrabold text-stone-900 my-4">学习</h2>
            <p id="quiz-meaning-hint" class="text-stone-500 text-sm">뜻: 공부하다</p>
        </div>

        <div id="quiz-options" class="grid grid-cols-1 gap-3 mt-4"></div>
    </div>

    <div id="result-view" class="container mx-auto px-4 max-w-md flex-grow hidden flex-col justify-between py-6">
        <div class="text-center pt-6">
            <h2 class="text-2xl font-extrabold text-stone-900 mb-6">테스트 결과 리포트</h2>
            <div class="bg-white border border-stone-200 shadow-sm rounded-3xl p-6 mb-6">
                <div class="inline-flex p-4 bg-emerald-50 rounded-full text-emerald-600 text-3xl mb-3">
                    <i class="fa-solid fa-award"></i>
                </div>
                <div class="text-4xl font-black text-stone-900 mb-1"><span id="final-score">0</span>점</div>
                <p class="text-stone-500 text-sm">맞춘 개수: <span id="final-correct">0</span> / 10</p>
                <div class="mt-4 inline-block px-4 py-1.5 rounded-full text-xs font-bold" id="final-grade-badge">
                    등급: <span id="final-grade">-</span>
                </div>
            </div>
        </div>

        <div class="flex-grow flex flex-col mb-6 min-h-0">
            <h3 class="text-sm font-bold text-stone-700 mb-2 flex items-center gap-1.5 px-1">
                <i class="fa-solid fa-book-open text-red-500"></i> 오답 아카이빙 노트
            </h3>
            <div id="wrong-words-container" class="bg-white border border-stone-200 rounded-2xl flex-grow overflow-y-auto p-4 space-y-3 max-h-48"></div>
        </div>

        <button onclick="switchView('home-view')" class="w-full py-4 bg-stone-900 hover:bg-stone-800 text-white font-bold rounded-xl shadow-md flex items-center justify-center gap-2 cursor-pointer">
            <i class="fa-solid fa-rotate-left"></i> 다시 처음으로 돌아가기
        </button>
    </div>

    <script>
        const mockVocabulary = [
            { hanzi: "学习", pinyin: "xuéxí", meaning: "공부하다", wrongPinyins: ["xuēxī", "xuéxǐ", "xuèxí"] },
            { hanzi: "汉字", pinyin: "hànzì", meaning: "한자", wrongPinyins: ["hānzì", "hànzī", "hánzǐ"] },
            { hanzi: "老师", pinyin: "lǎoshī", meaning: "선생님", wrongPinyins: ["láoshī", "lǎoshǐ", "lāoshī"] },
            { hanzi: "中国", pinyin: "zhōngguó", meaning: "중국", wrongPinyins: ["zhòngguó", "zhōngguǒ", "zhōngguō"] },
            { hanzi: "苹果", pinyin: "píngguǒ", meaning: "사과", wrongPinyins: ["píngguō", "pīngguǒ", "pǐngguǒ"] },
            { hanzi: "高兴", pinyin: "gāoxìng", meaning: "기쁘다", wrongPinyins: ["gāoxīng", "gǎoxìng", "gáoxìng"] },
            { hanzi: "谢谢", pinyin: "xièxie", meaning: "고맙다", wrongPinyins: ["xiēxiē", "xièxié", "xiěxie"] },
            { hanzi: "准备", pinyin: "zhǔnbèi", meaning: "준비하다", wrongPinyins: ["zhūnbèi", "zhǔnbēi", "zhùnbèi"] },
            { hanzi: "考试", pinyin: "kǎoshì", meaning: "시험", wrongPinyins: ["kāoshì", "kǎoshī", "kǎoshǐ"] },
            { hanzi: "大学", pinyin: "dàxué", meaning: "대학교", wrongPinyins: ["dāxué", "dàxuē", "dáxué"] },
            { hanzi: "现在", pinyin: "xiànzài", meaning: "지금", wrongPinyins: ["xiānzài", "xiànzāi", "xiánzài"] },
            { hanzi: "喜欢", pinyin: "xǐhuan", meaning: "좋아하다", wrongPinyins: ["xīhuan", "xǐhuān", "xǐhuán"] },
            { hanzi: "朋友", pinyin: "péngyou", meaning: "친구", wrongPinyins: ["pēngyou", "péngyóu", "pěngyou"] },
            { hanzi: "时间", pinyin: "shíjiān", meaning: "시간", wrongPinyins: ["shījiān", "shíjiǎn", "shìjiān"] },
            { hanzi: "面包", pinyin: "miànbāo", meaning: "빵", wrongPinyins: ["miánbāo", "miànbǎo", "miānbāo"] },
            { hanzi: "咖啡", pinyin: "kāfēi", meaning: "커피", wrongPinyins: ["kǎfēi", "kāfěi", "káfēi"] },
            { hanzi: "容易", pinyin: "róngyì", meaning: "쉽다", wrongPinyins: ["rōngyì", "róngyī", "rǒngyì"] },
            { hanzi: "意思", pinyin: "yìsi", meaning: "의미, 뜻", wrongPinyins: ["yīsī", "yìsī", "yísi"] },
            { hanzi: "欢迎", pinyin: "huānyíng", meaning: "환영하다", wrongPinyins: ["huānyīng", "huànyíng", "huǎnyíng"] },
            { hanzi: "回答", pinyin: "huídá", meaning: "대답하다", wrongPinyins: ["huīdá", "huídā", "huǐdá"] }
        ];

        let isFlipped = false;
        let currentFlashIndex = 0;
        let reviewFilterActive = false;
        let activeWordSet = [...mockVocabulary];
        let reviewStorage = JSON.parse(localStorage.getItem('china_quiz_review')) || {};

        let quizQuestions = [];
        let currentQuizIndex = 0;
        let score = 0;
        let correctCount = 0;
        let timerInterval;
        let timeLeft = 10;
        let wrongQuizWords = [];

        function switchView(viewId) {
            document.getElementById('home-view').classList.add('hidden');
            document.getElementById('flashcard-view').classList.add('hidden');
            document.getElementById('quiz-view').classList.add('hidden');
            document.getElementById('result-view').classList.add('hidden');
            
            document.getElementById(viewId).classList.remove('hidden');
            document.getElementById(viewId).classList.add('flex');
            
            if(viewId !== 'quiz-view') clearInterval(timerInterval);
        }

        function initFlashcard() {
            isFlipped = false;
            currentFlashIndex = 0;
            document.getElementById('flashcard').classList.remove('rotate-y-180');
            applyFilterLogic();
        }

        function applyFilterLogic() {
            if (reviewFilterActive) {
                activeWordSet = mockVocabulary.filter(item => reviewStorage[item.hanzi] === 'know-not');
            } else {
                activeWordSet = [...mockVocabulary];
            }
            
            if (activeWordSet.length === 0) {
                alert("해당 조건의 단어가 없어 기본 단어장으로 시작합니다.");
                document.getElementById('filter-review').checked = false;
                reviewFilterActive = false;
                activeWordSet = [...mockVocabulary];
            }
            renderFlashcard();
        }

        function toggleFilter(checkbox) {
            reviewFilterActive = checkbox.checked;
            initFlashcard();
        }

        function renderFlashcard() {
            if (currentFlashIndex >= activeWordSet.length) {
                alert("학습이 완료되어 처음 단어로 돌아갑니다.");
                currentFlashIndex = 0;
            }
            const currentWord = activeWordSet[currentFlashIndex];
            document.getElementById('flashcard').classList.remove('rotate-y-180');
            isFlipped = false;

            setTimeout(() => {
                document.getElementById('card-hanzi').innerText = currentWord.hanzi;
                document.getElementById('card-pinyin').innerText = currentWord.pinyin;
                document.getElementById('card-meaning').innerText = currentWord.meaning;
                const progressPct = ((currentFlashIndex + 1) / activeWordSet.length) * 100;
                document.getElementById('flashcard-progress').style.width = `${progressPct}%`;
            }, 150);
        }

        function flipCard() {
            isFlipped = !isFlipped;
            document.getElementById('flashcard').classList.toggle('rotate-y-180', isFlipped);
        }

        function classifyWord(isKnow) {
            const currentWord = activeWordSet[currentFlashIndex];
            reviewStorage[currentWord.hanzi] = isKnow ? 'know' : 'know-not';
            localStorage.setItem('china_quiz_review', JSON.stringify(reviewStorage));
            currentFlashIndex++;
            renderFlashcard();
        }

        function startQuiz() {
            score = 0; correctCount = 0; currentQuizIndex = 0; wrongQuizWords = [];
            document.getElementById('quiz-score').innerText = score;
            quizQuestions = [...mockVocabulary].sort(() => 0.5 - Math.random()).slice(0, 10);
            renderQuizQuestion();
        }

        function renderQuizQuestion() {
            if (currentQuizIndex >= quizQuestions.length) { endQuiz(); return; }
            document.getElementById('quiz-feedback').classList.add('hidden');
            document.getElementById('quiz-progress-txt').innerText = `문제 ${currentQuizIndex + 1} / 10`;
            
            const q = quizQuestions[currentQuizIndex];
            document.getElementById('quiz-hanzi').innerText = q.hanzi;
            document.getElementById('quiz-meaning-hint').innerText = `뜻: ${q.meaning}`;

            const options = [q.pinyin, ...q.wrongPinyins].sort(() => 0.5 - Math.random());
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';

            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = "quiz-opt-btn w-full py-3.5 px-6 bg-white text-stone-700 font-semibold border border-stone-200 rounded-xl hover:bg-stone-50 text-left flex justify-between items-center cursor-pointer";
                btn.innerHTML = `<span>${opt}</span> <i class="fa-solid fa-chevron-right text-stone-300 text-xs"></i>`;
                btn.onclick = () => checkQuizAnswer(btn, opt, q.pinyin);
                optionsContainer.appendChild(btn);
            });
            startTimer();
        }

        function startTimer() {
            clearInterval(timerInterval);
            timeLeft = 10;
            const timerBar = document.getElementById('timer-bar');
            timerBar.style.width = '100%';
            timerBar.style.backgroundColor = '#f59e0b';

            timerInterval = setInterval(() => {
                timeLeft--;
                timerBar.style.width = `${timeLeft * 10}%`;
                if (timeLeft <= 3) timerBar.style.backgroundColor = '#ef4444';
                if (timeLeft <= 0) { clearInterval(timerInterval); handleQuizResult(false, "시간 초과!"); }
            }, 1000);
        }

        function checkQuizAnswer(clickedBtn, selected, correct) {
            clearInterval(timerInterval);
            document.querySelectorAll('.quiz-opt-btn').forEach(btn => btn.disabled = true);
            const isCorrect = (selected === correct);
            
            if (isCorrect) {
                score += 10; correctCount++;
                document.getElementById('quiz-score').innerText = score;
                clickedBtn.className = "quiz-opt-btn w-full py-3.5 px-6 bg-emerald-500 text-white font-semibold rounded-xl text-left flex justify-between items-center";
                clickedBtn.innerHTML = `<span>${selected}</span> <i class="fa-solid fa-circle-check"></i>`;
                handleQuizResult(true, "정답입니다!");
            } else {
                clickedBtn.className = "quiz-opt-btn w-full py-3.5 px-6 bg-red-500 text-white font-semibold rounded-xl text-left flex justify-between items-center";
                clickedBtn.innerHTML = `<span>${selected}</span> <i class="fa-solid fa-circle-xmark"></i>`;
                document.querySelectorAll('.quiz-opt-btn').forEach(btn => {
                    if(btn.innerText.trim() === correct) btn.className = "quiz-opt-btn w-full py-3.5 px-6 bg-emerald-100 text-emerald-800 border border-emerald-300 font-semibold rounded-xl text-left flex justify-between items-center";
                });
                wrongQuizWords.push(quizQuestions[currentQuizIndex]);
                handleQuizResult(false, `오답! 정답은 ${correct}`);
            }
        }

        function handleQuizResult(isCorrect, text) {
            const feedbackLayer = document.getElementById('quiz-feedback');
            const feedbackIcon = document.getElementById('feedback-icon');
            const feedbackText = document.getElementById('feedback-text');

            feedbackIcon.innerHTML = isCorrect ? "<i class='fa-regular fa-circle-check text-emerald-500'></i>" : "<i class='fa-regular fa-circle-xmark text-red-500'></i>";
            feedbackText.className = isCorrect ? "text-lg font-bold text-emerald-600" : "text-lg font-bold text-red-600";
            feedbackText.innerText = text;
            feedbackLayer.classList.remove('hidden');

            setTimeout(() => { currentQuizIndex++; renderQuizQuestion(); }, 1300);
        }

        function endQuiz() {
            switchView('result-view');
            document.getElementById('final-score').innerText = score;
            document.getElementById('final-correct').innerText = correctCount;

            let alphaGrade = score >= 90 ? "A+" : score >= 70 ? "A" : score >= 50 ? "B" : "재시험 권장";
            document.getElementById('final-grade').innerText = alphaGrade;

            const wrongContainer = document.getElementById('wrong-words-container');
            wrongContainer.innerHTML = '';

            if (wrongQuizWords.length === 0) {
                wrongContainer.innerHTML = `<div class="text-center py-6 text-stone-400 text-sm">틀린 문제가 없습니다! 완벽해요!</div>`;
            } else {
                wrongQuizWords.forEach(word => {
                    const item = document.createElement('div');
                    item.className = "flex justify-between items-center p-3 bg-stone-50 border border-stone-200 rounded-xl";
                    item.innerHTML = `<div><span class="text-lg font-bold text-stone-900">${word.hanzi}</span><span class="text-sm text-emerald-600 ml-2">[${word.pinyin}]</span></div><span class="text-xs text-stone-500">${word.meaning}</span>`;
                    wrongContainer.appendChild(item);
                });
            }
        }
    </script>
</body>
</html>
